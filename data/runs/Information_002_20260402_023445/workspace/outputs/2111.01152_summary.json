  "derivation": {
    "single_particle_continuum_H_tau": "H_{\\tau}=\\begin{pmatrix}\n        -\\frac{\\hbar^2\\bm{k}^2}{2m_\\mathfrak{b}}+\\Delta_{\\mathfrak{b}}(\\bm{r}) &  \\Delta_{\\text{T},\\tau}(\\bm{r})\\\\\n        \\Delta_{\\text{T},\\tau}^\\dag(\\bm{r}) & -\\frac{\\hbar^2\\left(\\bm{k}-\\tau \\bm{\\kappa}\\right)^2}{2m_\\mathfrak{t}}+ \\Delta_\\mathfrak{t}(\\bm{r})+V_{z\\mathfrak{t}}\n    \\end{pmatrix},",
    "delta_b": "\\Delta_{\\mathfrak{b}}(\\bm{r})=2V_{\\mathfrak{b}}\\sum_{j=1,3,5} \\cos(\\bm{g}_j \\cdot \\bm{r}+\\psi_{\\mathfrak{b}}),",
    "delta_T_tau": "\\Delta_{\\text{T},\\tau}(\\bm{r})=\\tau w \\left(1+\\omega^{\\tau} e^{i\\tau\\bm{g}_2\\cdot\\bm{r}}+\\omega^{2\\tau} e^{i\\tau\\bm{g}_3\\cdot\\bm{r}} \\right),",
    "second_quantized_real_space": "\\hat{\\mathcal{H}}_0=\\sum_{\\tau=\\pm}\\int d^2\\bm{r}\\,\\Psi_{\\tau}^{\\dagger}(\\bm{r})H_{\\tau}\\Psi_{\\tau}(\\bm{r})",
    "momentum_space_noninteracting": "\\hat{\\mathcal{H}}_0=\\sum_{\\bm{k}_{\\alpha},\\bm{k}_{\\beta}}\\sum_{l_{\\alpha},l_{\\beta}}\\sum_{\\tau} h^{(\\tau)}_{\\bm{k}_{\\alpha}l_{\\alpha},\\bm{k}_{\\beta}l_{\\beta}} c^{\\dagger}_{\\bm{k}_{\\alpha},l_{\\alpha},\\tau}c_{\\bm{k}_{\\beta},l_{\\beta},\\tau}",
    "hole_basis_noninteracting": "\\hat{\\mathcal{H}}_0=\\sum_{\\tau}\\mathrm{Tr}\\,h^{(\\tau)}-\\sum_{\\bm{k}_{\\alpha},\\bm{k}_{\\beta}}\\sum_{l_{\\alpha},l_{\\beta}}\\sum_{\\tau}[h^{(\\tau)}]^{\\intercal}_{\\bm{k}_{\\alpha}l_{\\alpha},\\bm{k}_{\\beta}l_{\\beta}} b^{\\dagger}_{\\bm{k}_{\\alpha},l_{\\alpha},\\tau}b_{\\bm{k}_{\\beta},l_{\\beta},\\tau}",
    "full_interacting_hamiltonian": "\\begin{split}\n    \\hat{\\mathcal{H}}&=\\hat{\\mathcal{H}}_1+\\hat{\\mathcal{H}}_{\\text{int}},\\\\\n        \\hat{\\mathcal{H}}_1&=\\sum_{\\bm{k}_{\\alpha},\\bm{k}_{\\beta}}\\sum_{l_{\\alpha},l_{\\beta}}\\sum_{\\tau} \\tilde{h}^{(\\tau)}_{\\bm{k}_{\\alpha}l_{\\alpha},\\bm{k}_{\\beta}l_{\\beta}} b_{\\bm{k}_{\\alpha},l_{\\alpha},\\tau}^\\dagger b_{\\bm{k}_{\\beta},l_{\\beta},\\tau},\\\\\n        \\hat{\\mathcal{H}}_{\\text{int}}&=\\frac{1}{2A} \\sum_{\\bm{k}_{\\alpha},\\bm{k}_{\\beta},\\bm{k}_{\\gamma},\\bm{k}_{\\delta}  }\\sum_{l_{\\alpha},l_{\\beta}}\\sum_{\\tau_{\\alpha},\\tau_{\\beta}} V(\\bm{k}_{\\alpha}-\\bm{k}_{\\delta}) b_{\\bm{k}_{\\alpha},l_{\\alpha},\\tau_{\\alpha}}^\\dagger b_{\\bm{k}_{\\beta},l_{\\beta},\\tau_{\\beta}}^\\dagger b_{\\bm{k}_{\\gamma},l_{\\beta},\\tau_{\\beta}} b_{\\bm{k}_{\\delta},l_{\\alpha},\\tau_{\\alpha}} \\delta_{\\bm{k}_{\\alpha}+\\bm{k}_{\\beta}, \\bm{k}_{\\delta}+\\bm{k}_{\\gamma}},\n    \\end{split}",
    "hartree_fock_from_supplement": "\\begin{aligned}\n    \\hat{\\mathcal{H}}^{\\text{HF}}&=\\hat{\\mathcal{H}}_1 +\\hat{\\mathcal{H}}_{\\text{int}}^{\\text{HF}},\\\\\n    \\hat{\\mathcal{H}}_{\\text{int}}^{\\text{HF}}&=\\frac{1}{A} \\sum_{\\bm{k}_{\\alpha},\\bm{k}_{\\beta},\\bm{k}_{\\gamma},\\bm{k}_{\\delta}  }\\sum_{l_{\\alpha},l_{\\beta}}\\sum_{\\tau_{\\alpha},\\tau_{\\beta}} V(\\bm{k}_{\\alpha}-\\bm{k}_{\\delta})\\biggl( \\expval{b_{\\bm{k}_{\\alpha},l_{\\alpha},\\tau_{\\alpha}}^\\dagger b_{\\bm{k}_{\\delta},l_{\\alpha},\\tau_{\\alpha}}} b_{\\bm{k}_{\\beta},l_{\\beta},\\tau_{\\beta}}^\\dagger b_{\\bm{k}_{\\gamma},l_{\\beta},\\tau_{\\beta}}\\\\\n        &-\\expval{b_{\\bm{k}_{\\alpha},l_{\\alpha},\\tau_{\\alpha}}^\\dagger b_{\\bm{k}_{\\gamma},l_{\\beta},\\tau_{\\beta}} }b_{\\bm{k}_{\\beta},l_{\\beta},\\tau_{\\beta}}^\\dagger b_{\\bm{k}_{\\delta},l_{\\alpha},\\tau_{\\alpha}}\\biggr) \\delta_{\\bm{k}_{\\alpha}+\\bm{k}_{\\beta}, \\bm{k}_{\\delta}+\\bm{k}_{\\gamma}}.\n    \\end{aligned}",
    "reduced_hartree_term": "$H_{\\text{Hartree}} = \\frac{1}{V}\\sum_{\\tau_1,\\tau_2,l_1,l_2,k_1,k_2,q_1,q_2,q_3,q_4} \\langle b_{l_1,\\tau_1,q_1}^\\dagger(k_1) b_{l_1,\\tau_1,q_4}(k_1) \\rangle b_{l_2,\\tau_2,q_2}^\\dagger(k_2) b_{l_2,\\tau_2,q_3}(k_2)  V(|q_1-q_4|)\\delta_{q_1+q_2,q_3+q_4}$",
    "reduced_fock_term": "$H_{\\text{Fock}} = -\\frac{1}{V}\\sum_{\\tau_1,\\tau_2,l_1,l_2,k_1,k_2,q_1,q_2,q_3,q_4} \\langle b_{l_1,\\tau_1,q_1}^\\dagger(k_1) b_{l_2,\\tau_2,q_3}(k_1) \\rangle b_{l_2,\\tau_2,q_2}^\\dagger(k_2) b_{l_1,\\tau_1,q_4}(k_2) V(|k_1+q_1-k_2-q_4|)\\delta_{q_1+q_2,q_3+q_4}$",
    "combined_hartree_fock_hamiltonian": "\\hat{\\mathcal{H}}^{\\mathrm{HF}}=\\hat{\\mathcal{H}}_1+H_{\\mathrm{Hartree}}+H_{\\mathrm{Fock}},\\quad \\hat{\\mathcal{H}}_1=\\sum_{\\bm{k}_{\\alpha},\\bm{k}_{\\beta}}\\sum_{l_{\\alpha},l_{\\beta}}\\sum_{\\tau}\\tilde{h}^{(\\tau)}_{\\bm{k}_{\\alpha}l_{\\alpha},\\bm{k}_{\\beta}l_{\\beta}}b^{\\dagger}_{\\bm{k}_{\\alpha},l_{\\alpha},\\tau}b_{\\bm{k}_{\\beta},l_{\\beta},\\tau}"
  }
